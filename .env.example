VITE_API_URL=http://localhost:5000/api/v1
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_ESCROW_CONTRACT_ID=CA...
VITE_PLATFORM_FEE_ACCOUNT=GA...

# The public URL of this frontend application.
# Used by the backend (APP_CLIENT_URL) to construct OAuth redirect URIs,
# e.g. for CalendarController.googleCallback → /settings/calendar.
# In development this is typically http://localhost:5173 (Vite default) or
# http://localhost:3000 depending on your dev server port.
# In production set this to your actual domain, e.g. https://app.mentorsmind.com
# The frontend itself derives its origin from window.location.origin at runtime
# so this variable is primarily documentation for the backend team.
VITE_APP_CLIENT_URL=http://localhost:5173
